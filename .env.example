# AutoResearchClaw — variables de entorno
# Copia este archivo a .env y rellena tus claves:
#   cp .env.example .env
#
# .env está en .gitignore — nunca subas tus claves reales al repositorio.

# ── LLM (requerido para Modo B — CLI pipeline) ────────────────────────────
# Para Ollama local (Modo A — Web UI) no necesitas esta variable.
OPENAI_API_KEY=

# ── Búsqueda bibliográfica (opcionales — aumentan límites de tasa) ─────────
# Semantic Scholar API key: https://www.semanticscholar.org/product/api
S2_API_KEY=

# Scite.ai API key: https://scite.ai/api
SCITE_API_KEY=
